# Telegram Bot
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_ADMIN_CHAT_ID=your_chat_id_here  # Запустите: python scripts/get_chat_id.py

# Avito (для браузерной автоматизации)
AVITO_LOGIN=+79990000000
AVITO_PASSWORD=your_password

# Avito API (опционально)
AVITO_CLIENT_ID=
AVITO_CLIENT_SECRET=
AVITO_ACCESS_TOKEN=
AVITO_REFRESH_TOKEN=

# Telephony (Voximplant)
VOXIMPLANT_ACCOUNT_ID=
VOXIMPLANT_API_KEY=
VOXIMPLANT_PHONE_NUMBER=

# Twilio (альтернатива)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# База данных
DATABASE_PATH=./data/recruitment.db

# Оркестратор
ORCHESTRATOR_HOST=0.0.0.0
ORCHESTRATOR_PORT=8000

# Web App URL (для Telegram приглашений)
WEBAPP_URL=http://localhost:8080

# Логирование
LOG_LEVEL=INFO

# Режим разработки
DEBUG=true
